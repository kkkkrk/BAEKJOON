#include <bits/stdc++.h>
using namespace std;
int N,M, ret;
int sum = 0;
int dy[] = {0,1,0,-1};
int dx[] = {1,0,-1,0};
bool visited[501][501];
int a[501][501];
void dfs(int y, int x, int cnt){
    if(cnt >= 4){
        ret = max(ret, sum);
        return;
    }
    for(int i = 0;i < 4;i++){
        int ny = y + dy[i];
        int nx = x + dx[i];
        if(ny < 0 || ny >= N || nx < 0 || nx >= M || visited[ny][nx]) continue;
        sum += a[ny][nx];
        visited[ny][nx] = 1;
        dfs(ny,nx,cnt+1);
        sum -= a[ny][nx];
        visited[ny][nx] = 0;
    }
}
int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(NULL); cout.tie(NULL);
    cin >> N >> M;
    for(int i = 0;i < N;i++){
        for(int j = 0;j < M;j++){
            cin >> a[i][j];
        }
    }
    memset(visited, 0, sizeof(visited));
    for(int i = 0;i < N;i++){
        for(int j = 0;j < M;j++){
            sum = a[i][j];
            visited[i][j] = 1;
            dfs(i,j, 1);
            visited[i][j] = 0;
        }
    }
    for(int i = 0;i < N;i++){
        for(int j = 0;j < M;j++){
            if(j+2 < M && i + 1 < N) ret = max(ret, (a[i][j] + a[i][j+1] + a[i][j+2] + a[i+1][j+1]));
            if(j+2 < M && i + 1 < N) ret = max(ret, (a[i+1][j] + a[i+1][j+1] + a[i+1][j+2] + a[i][j+1]));
            if(j+1 < M && i + 2 < N) ret = max(ret, (a[i][j] + a[i+1][j] + a[i+2][j] + a[i+1][j+1]));
            if(j+1 < M && i + 2 < N) ret = max(ret, (a[i][j+1] + a[i+1][j+1] + a[i+2][j+1] + a[i+1][j]));
        }
    }
    cout << ret;
    return 0;
}
